# OwlTP Security Configuration Example
# Copy this to .env and fill in the values

# Environment (development/production)
ENV=development

# Database & Redis
DATABASE_URL=postgresql://admin:password123@db:5432/whatsapp_otp
REDIS_URL=redis://redis:6379/0

# Security Secrets (CHANGE THESE IN PRODUCTION!)
# Generat JWT_SECRET: openssl rand -hex 32
JWT_SECRET=supersecretkey_change_me_in_prod

# SMTP Encryption (32-byte Base64 key)
# Generate via: from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())
SMTP_ENCRYPTION_KEY=

# CORS (Comma-separated origins)
CORS_ORIGINS=http://localhost:3000,https://yourdashboard.com
